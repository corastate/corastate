    "@fastify/sensible": "^5.6.0",
    "drizzle-orm": "^0.36.1",
    "fastify": "^4.28.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "postgres": "^3.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@corastate/connector-defender": "workspace:*",
    "@corastate/connector-okta": "workspace:*",
    "@corastate/connector-sdk": "workspace:*",
    "@types/node": "^20.14.10",
    "dotenv-cli": "^7.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
