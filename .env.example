# Copy this file to .env and adjust as needed.
# The web app, backend, CLI, sync worker, and Drizzle migrations read from these.

# --- Postgres (matches docker-compose.yml defaults) ---
POSTGRES_USER=corastate
POSTGRES_PASSWORD=corastate
POSTGRES_DB=corastate
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# DATABASE_URL is what the app code and Drizzle read.
DATABASE_URL=postgres://corastate:corastate@localhost:5432/corastate

# --- Backend HTTP ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=4000

# --- Logging ---
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info
# Set to 1 for human-readable logs in dev (pino-pretty).
LOG_PRETTY=1

# --- Web dev server (Vite) ---
VITE_API_BASE_URL=http://localhost:4000

# --- Credential store master key ---
# Base64-encoded 32 bytes for AES-256-GCM. Read by EnvKeyProvider in the
# sync worker process only; the API process must NOT have this set.
# Generate with: openssl rand -base64 32
CORASTATE_MASTER_KEY=

# --- Connector credentials ---
# Connector secrets are stored in the encrypted credentials table, NOT in
# environment variables (architecture-v3 §"Credential and security
# architecture"). The CLI command for loading them lands with the runner
# in Phase 1 Week 2.
