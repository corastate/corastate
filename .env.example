# Copy this file to .env (`cp .env.example .env`) for the `pnpm dev` path.
# Docker Compose has the same defaults baked in, so `docker compose up`
# works with no .env at all.
#
# This file is committed and holds literal values. The maintainer's own
# .env.local pulls live secrets through 1Password (`op run --env-file=.env.local
# -- pnpm dev`); that flow is independent of this file and unchanged.

# --- Postgres (matches docker-compose.yml defaults) ---
POSTGRES_USER=corastate
POSTGRES_PASSWORD=corastate
POSTGRES_DB=corastate
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# DATABASE_URL is what the app code and Drizzle read. The host is `localhost`
# for the `pnpm dev` path; inside compose this is overridden to `postgres`
# (the service name) by docker-compose.yml.
DATABASE_URL=postgres://corastate:corastate@localhost:5432/corastate

# --- Backend HTTP ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=4000

# --- Logging ---
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info
# Set to 1 for human-readable logs in dev (pino-pretty).
LOG_PRETTY=1

# --- Web dev server (Vite) ---
VITE_API_BASE_URL=http://localhost:4000

# --- Credential store master key ---
# Base64-encoded 32 bytes for AES-256-GCM. Read by EnvKeyProvider in the
# sync worker process only; the API process must NOT have this set.
#
# The value below is 32 zero bytes, demo-only, fine for the seeded data
# path because the demo sources are inactive and no real vendor secrets
# touch the credential store. Generate your own for any install that will
# hold live credentials:
#
#   openssl rand -base64 32
CORASTATE_MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# --- Connector credentials ---
# Real connector secrets are stored in the encrypted credentials table, NOT
# in environment variables (architecture-v3 §"Credential and security
# architecture"). The CLI loads them via `corastate sync` setup commands.
