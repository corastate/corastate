{
  "name": "@corastate/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": ["src"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "dotenv -e ../../.env -- vitest run",
    "test:ci": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@corastate/connector-sdk": "workspace:*",
    "@corastate/contracts": "workspace:*",
    "@corastate/db": "workspace:*",
    "drizzle-orm": "^0.36.1",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "dotenv-cli": "^7.4.2",
    "postgres": "^3.4.4",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
