{
  "name": "@corastate/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "import": "./src/schema.ts",
      "default": "./src/schema.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./src/client.ts",
      "default": "./src/client.ts"
    }
  },
  "files": ["src", "drizzle"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "generate": "dotenv -e ../../.env -- drizzle-kit generate",
    "push": "dotenv -e ../../.env -- drizzle-kit push",
    "studio": "dotenv -e ../../.env -- drizzle-kit studio",
    "migrate": "dotenv -e ../../.env -- tsx src/migrate.ts",
    "roll-partitions": "dotenv -e ../../.env -- tsx src/roll-partitions.ts",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.1",
    "postgres": "^3.4.4",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "dotenv-cli": "^7.4.2",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
