{
  "name": "@corastate/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./device": {
      "types": "./src/device.ts",
      "import": "./src/device.ts",
      "default": "./src/device.ts"
    },
    "./identity": {
      "types": "./src/identity.ts",
      "import": "./src/identity.ts",
      "default": "./src/identity.ts"
    },
    "./correlation-config": {
      "types": "./src/correlation-config.ts",
      "import": "./src/correlation-config.ts",
      "default": "./src/correlation-config.ts"
    },
    "./api": {
      "types": "./src/api.ts",
      "import": "./src/api.ts",
      "default": "./src/api.ts"
    }
  },
  "files": ["src"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
